{
  "name": "@sri-xml-viewer/vue",
  "version": "1.2.4",
  "description": "Vue 3 viewer components for SRI Ecuador XML electronic vouchers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css",
    "./standalone.css": "./dist/standalone.css",
    "./style.css": "./dist/theme.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --declarationDir dist && npm run build:css",
    "build:css": "node -e \"require('fs').copyFileSync('src/theme.css','dist/theme.css')\" && npx @tailwindcss/cli -i src/standalone-entry.css -o dist/standalone.css --minify",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@sri-xml-viewer/core": "workspace:^",
    "jsbarcode": "^3.12.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^2.0.0"
  }
}
