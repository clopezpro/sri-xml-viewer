{
  "name": "sri-xml-viewer",
  "version": "1.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "description": "Monorepo for SRI Ecuador XML electronic voucher parser and viewer (Vue & React)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp package.json packages/*/package.json --commit --tag --push"
  },
  "devDependencies": {
    "bumpp": "^11.1.0",
    "changelogithub": "^14.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8.61.0"
  }
}
